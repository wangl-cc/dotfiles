mode = "symlink"

[data.mirrors]
{{- /* Use mirrors in China, we determine if in China by comparing tzdata */}}
enabled = {{ eq (include "/etc/localtime" | sha1sum)  "79360e38e040eaa15b6e880296c1d1531f537b6f" }}

[data.homebrew]
{{- /* Determine homebrew prefix based on OS and arch */}}
prefix = {{ if eq .chezmoi.os "darwin" -}}
  {{- if eq .chezmoi.arch "arm64" -}}
    "/opt/homebrew"
  {{- else -}}
    "/usr/local"
  {{- end -}}
{{- else -}}
  "/home/linuxbrew/.linuxbrew"
{{- end }}

{{- $aquaRootDir := joinPath .chezmoi.homeDir ".local/share/aquaproj-aqua" }}
{{- $aquaConfigDir := joinPath .chezmoi.homeDir ".config/aquaproj-aqua" }}
{{- $aquaSourceConfigDir := joinPath .chezmoi.sourceDir "dot_config/aquaproj-aqua" }}
[data.aqua]
rootDir = {{ $aquaRootDir | quote }}
binDir = {{ joinPath $aquaRootDir "bin" | quote }}
bin = {{ joinPath $aquaRootDir "bin" "aqua" | quote }}
configDir = {{ $aquaConfigDir | quote }}
localConfig = {{ joinPath $aquaConfigDir "local.yaml" | quote }}
sharedConfig = {{ joinPath $aquaConfigDir "shared.yaml" | quote }}
fishConfig = {{ joinPath $aquaConfigDir "fish.yaml" | quote }}
sourceConfigDir = {{ $aquaSourceConfigDir | quote }}
sourceSharedConfig = {{ joinPath $aquaSourceConfigDir "shared.yaml" | quote }}
sourceFishConfig = {{ joinPath $aquaSourceConfigDir "fish.yaml" | quote }}

[data.shell.fish]
auto = {{ promptBoolOnce . "shell.fish.auto" "Auto-enter fish from fallback bash/zsh sessions" true }}
portable = {{ promptBoolOnce . "shell.fish.portable" "Install fish with aqua on this machine" false }}

[data.toolchains]
uv = {{ promptBoolOnce . "toolchains.uv" "Install uv with Astral's official installer on this machine" true }}
rustup = {{ promptChoiceOnce . "toolchains.rustup" "Rustup profile to install on this machine" (list "none" "minimal" "default" "complete") "none" | quote }}
bun = {{ promptBoolOnce . "toolchains.bun" "Install Bun with Bun's official installer on this machine" true }}

[data.git]
name = "Loong"
email = "git@loongw.cc"
{{- $gitSigningKeyFiles := glob (joinPath .chezmoi.homeDir ".ssh/*.pub") }}
{{- $gitSigningDisabled := "none" }}
{{- $gitSigningKeyChoices := list $gitSigningDisabled }}
{{- range $gitSigningKeyPath := $gitSigningKeyFiles }}
{{-   $gitSigningKeyChoices = append $gitSigningKeyChoices (trimSuffix ".pub" (base $gitSigningKeyPath)) }}
{{- end }}
{{- $gitSigningKeySelection := promptChoiceOnce . "git.signingkeyFile" "Git SSH commit signing public key" $gitSigningKeyChoices $gitSigningDisabled }}
{{- $gitSigningKeyFile := "" }}
{{- if or (eq $gitSigningKeySelection "") (eq $gitSigningKeySelection $gitSigningDisabled) }}
{{- else if contains "/" $gitSigningKeySelection }}
{{-   $gitSigningKeyFile = $gitSigningKeySelection }}
{{- else if hasSuffix ".pub" $gitSigningKeySelection }}
{{-   $gitSigningKeyFile = printf "~/.ssh/%s" $gitSigningKeySelection }}
{{- else }}
{{-   $gitSigningKeyFile = printf "~/.ssh/%s.pub" $gitSigningKeySelection }}
{{- end }}
signingkeyFile = {{ $gitSigningKeyFile | quote }}
