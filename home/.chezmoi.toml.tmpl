mode = "symlink"

{{- $portableFish := promptBoolOnce . "portable_fish" "Use aqua to install a portable fish shell on this machine?" false }}
{{- $uv := promptBoolOnce . "toolchains.uv" "Install uv with Astral's official installer on this machine?" false }}
{{- $rustup := promptBoolOnce . "toolchains.rustup" "Install the Rust toolchain with rustup on this machine?" false }}
{{- $bun := promptBoolOnce . "toolchains.bun" "Install Bun with Bun's official installer on this machine?" false }}
{{- $gitSigningKeyFiles := glob (joinPath .chezmoi.homeDir ".ssh/*.pub") }}
{{- $gitSigningDisabled := "none" }}
{{- $gitSigningKeyChoices := list $gitSigningDisabled }}
{{- range $gitSigningKeyPath := $gitSigningKeyFiles }}
{{-   $gitSigningKeyChoices = append $gitSigningKeyChoices (trimSuffix ".pub" (base $gitSigningKeyPath)) }}
{{- end }}
{{- $gitSigningKeySelection := promptChoiceOnce . "git.signingkeyFile" "Git SSH commit signing public key" $gitSigningKeyChoices $gitSigningDisabled }}
{{- $gitSigningKeyFile := "" }}
{{- if or (eq $gitSigningKeySelection "") (eq $gitSigningKeySelection $gitSigningDisabled) }}
{{- else if contains "/" $gitSigningKeySelection }}
{{-   $gitSigningKeyFile = $gitSigningKeySelection }}
{{- else if hasSuffix ".pub" $gitSigningKeySelection }}
{{-   $gitSigningKeyFile = printf "~/.ssh/%s" $gitSigningKeySelection }}
{{- else }}
{{-   $gitSigningKeyFile = printf "~/.ssh/%s.pub" $gitSigningKeySelection }}
{{- end }}

[data]
portable_fish = {{ $portableFish }}

[data.mirrors]
{{- /* Use mirrors in China, we determine if in China by comparing tzdata */}}
enabled = {{ eq (include "/etc/localtime" | sha1sum)  "79360e38e040eaa15b6e880296c1d1531f537b6f" }}

[data.homebrew]
{{- /* Determine homebrew prefix based on OS and arch */}}
prefix = {{ if eq .chezmoi.os "darwin" -}}
  {{- if eq .chezmoi.arch "arm64" -}}
    "/opt/homebrew"
  {{- else -}}
    "/usr/local"
  {{- end -}}
{{- else -}}
  "/home/linuxbrew/.linuxbrew"
{{- end }}

[data.toolchains]
uv = {{ $uv }}
rustup = {{ $rustup }}
bun = {{ $bun }}

[data.git]
name = "Loong"
email = "git@loongw.cc"
signingkeyFile = {{ $gitSigningKeyFile | quote }}
