#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "tomlkit==0.13.3",
# ]
# ///
"""Apply portable Codex preferences without taking over dynamic state."""

from pathlib import Path
from typing import Any, TypeAlias

import tomlkit
from tomlkit.items import Array, Table


CONFIG_PATH = Path.home() / ".codex" / "config.toml"
UV_CACHE_DIR = Path.home() / ".cache" / "uv"
TomlContainer: TypeAlias = tomlkit.TOMLDocument | Table

TOP_LEVEL_SETTINGS: dict[str, object] = {
    "model": "gpt-5.5",
    "model_reasoning_effort": "high",
    "approval_policy": "on-request",
    "approvals_reviewer": "guardian_subagent",
    "sandbox_mode": "workspace-write",
}

FEATURE_SETTINGS: dict[str, object] = {
    "js_repl": False,
    "memories": True,
}

DESKTOP_SETTINGS: dict[str, object] = {
    "sansFontSize": 14,
    "codeFontSize": 13,
    "usePointerCursors": False,
    "dictationDictionary": [],
    "followUpQueueMode": "queue",
    "reviewDelivery": "detached",
    "preventSleepWhileRunning": True,
    "keepRemoteControlAwakeWhilePluggedIn": True,
    "git-always-force-push": True,
    "git-pull-request-merge-method": "squash",
    "notifications-turn-mode": "off",
    "conversationDetailMode": "STEPS_COMMANDS",
    "reduced-motion-preference": "system",
    "git-show-sidebar-pr-icons": True,
}


def read_document() -> tomlkit.TOMLDocument:
    if not CONFIG_PATH.exists():
        return tomlkit.document()
    return tomlkit.parse(CONFIG_PATH.read_text(encoding="utf-8"))


def ensure_table(container: TomlContainer, key: str) -> Table:
    value = container.get(key)
    if value is None:
        value = tomlkit.table()
        container[key] = value

    if not isinstance(value, Table):
        raise SystemExit(f"{key} must be a TOML table")
    return value


def ensure_table_path(document: tomlkit.TOMLDocument, path: tuple[str, ...]) -> Table:
    container: TomlContainer = document
    for key in path:
        container = ensure_table(container, key)
    if not isinstance(container, Table):
        raise SystemExit("table path must contain at least one key")
    return container


def set_values(container: TomlContainer, values: dict[str, object]) -> None:
    for key, value in values.items():
        container[key] = value


def string_value(value: Any) -> str | None:
    if isinstance(value, str):
        return value
    return None


def configured_roots(section: Table) -> list[str]:
    roots = section.get("writable_roots")
    if roots is None:
        return []
    if not isinstance(roots, Array):
        raise SystemExit("sandbox_workspace_write.writable_roots must be an array")

    values = [string_value(root) for root in roots]
    if any(root is None for root in values):
        raise SystemExit("sandbox_workspace_write.writable_roots must contain strings")
    return [root for root in values if root is not None]


def roots_array(roots: list[str]) -> Array:
    array = tomlkit.array()
    array.multiline(True)
    for root in roots:
        array.append(root)
    return array


def apply_portable_settings(document: tomlkit.TOMLDocument) -> None:
    set_values(document, TOP_LEVEL_SETTINGS)
    set_values(ensure_table(document, "features"), FEATURE_SETTINGS)
    set_values(ensure_table(document, "desktop"), DESKTOP_SETTINGS)

    open_in_targets = ensure_table_path(
        document, ("desktop", "open-in-target-preferences")
    )
    open_in_targets["global"] = "zed"

    openai_docs = ensure_table_path(document, ("mcp_servers", "openaiDeveloperDocs"))
    openai_docs["url"] = "https://developers.openai.com/mcp"


def apply_writable_roots(document: tomlkit.TOMLDocument) -> None:
    section = ensure_table(document, "sandbox_workspace_write")
    roots = configured_roots(section)
    root = str(UV_CACHE_DIR)
    if root not in roots:
        section["writable_roots"] = roots_array([*roots, root])


CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
UV_CACHE_DIR.mkdir(parents=True, exist_ok=True)

before = CONFIG_PATH.read_text(encoding="utf-8") if CONFIG_PATH.exists() else ""
document = read_document()
apply_portable_settings(document)
apply_writable_roots(document)

after = tomlkit.dumps(document)
if after != before:
    CONFIG_PATH.write_text(after, encoding="utf-8")
