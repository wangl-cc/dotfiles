#!/usr/bin/env bash
#
{{- $toolchains := get . "toolchains" | default dict }}
{{- $uv := get $toolchains "uv" | default false }}
{{- $rustup := get $toolchains "rustup" | default false }}
{{- $bun := get $toolchains "bun" | default false }}
# toolchains.uv={{ $uv }}
# toolchains.rustup={{ $rustup }}
# toolchains.bun={{ $bun }}

set -euo pipefail

fetch() {
    local url=$1

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url"
    elif command -v wget >/dev/null 2>&1; then
        wget -qO- "$url"
    else
        echo "Neither curl nor wget is available; cannot install language toolchains." >&2
        return 1
    fi
}

uv_bin="$HOME/.local/bin/uv"
rustup_bin="$HOME/.cargo/bin/rustup"
bun_bin="$HOME/.bun/bin/bun"

if [ "{{ $uv }}" = "true" ] &&
    ! command -v uv >/dev/null 2>&1 &&
    [ ! -x "$uv_bin" ]; then
    echo "Installing uv"
    fetch https://astral.sh/uv/install.sh | UV_NO_MODIFY_PATH=1 sh
fi

if [ "{{ $rustup }}" = "true" ] &&
    ! command -v rustup >/dev/null 2>&1 &&
    [ ! -x "$rustup_bin" ]; then
    echo "Installing rustup"
    fetch https://sh.rustup.rs | sh -s -- -y --no-modify-path --profile default
fi

if [ "{{ $bun }}" = "true" ] &&
    ! command -v bun >/dev/null 2>&1 &&
    [ ! -x "$bun_bin" ]; then
    echo "Installing bun"
    fetch https://bun.sh/install | BUN_INSTALL="$HOME/.bun" SHELL=/bin/sh bash
fi
