#!/usr/bin/env bash
#
# CHEZMOI_BOOTSTRAP_TOOLCHAINS={{ env "CHEZMOI_BOOTSTRAP_TOOLCHAINS" | quote }}

set -euo pipefail

if [ "${CHEZMOI_BOOTSTRAP_TOOLCHAINS:-}" != "1" ]; then
    exit 0
fi

fetch() {
    local url=$1

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url"
    elif command -v wget >/dev/null 2>&1; then
        wget -qO- "$url"
    else
        echo "Neither curl nor wget is available; cannot bootstrap toolchain managers." >&2
        return 1
    fi
}

uv_bin="$HOME/.local/bin/uv"
rustup_bin="$HOME/.cargo/bin/rustup"
mise_bin="$HOME/.local/bin/mise"

if ! command -v uv >/dev/null 2>&1 && [ ! -x "$uv_bin" ]; then
    echo "Installing uv"
    fetch https://astral.sh/uv/install.sh | UV_NO_MODIFY_PATH=1 sh
fi

if ! command -v rustup >/dev/null 2>&1 && [ ! -x "$rustup_bin" ]; then
    echo "Installing rustup"
    fetch https://sh.rustup.rs | sh -s -- -y --no-modify-path --profile default
fi

if ! command -v mise >/dev/null 2>&1 && [ ! -x "$mise_bin" ]; then
    echo "Installing mise"
    mkdir -p "$HOME/.local/bin"
    fetch https://mise.run | MISE_INSTALL_PATH="$mise_bin" sh
fi
