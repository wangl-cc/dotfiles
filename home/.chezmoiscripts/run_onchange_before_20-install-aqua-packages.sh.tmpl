#!/usr/bin/env bash

# {{- $fishPortable := dig "shell" "fish" "portable" false . -}}
#
# shared.yaml.sha256={{ include .aqua.sourceSharedConfig | sha256sum }}
# {{ if $fishPortable }}
# fish.yaml.sha256={{ include .aqua.sourceFishConfig | sha256sum }}
# {{ end }}

set -euo pipefail

# {{ if (isExecutable .aqua.bin) }}

# {{ $aquaEnabledConfig := list .aqua.sourceSharedConfig }}
# {{ if $fishPortable }}
# {{ $aquaEnabledConfig = append $aquaEnabledConfig .aqua.sourceFishConfig }}
# {{ end }}

export AQUA_ROOT_DIR="{{ .aqua.rootDir }}"
export AQUA_GLOBAL_CONFIG="{{ $aquaEnabledConfig | join ":" }}"
"{{ .aqua.bin }}" install --all

# {{ if not $fishPortable }}
remove_stale_aqua_fish_links() {
    local command link target

    # aqua install is additive: if fish was previously enabled and is later
    # removed from AQUA_GLOBAL_CONFIG, aqua does not prune the old proxy links
    # from bin/. Remove only aqua-proxy symlinks so shell.fish.portable=false
    # does not keep resolving fish from aqua ahead of system/Homebrew fish.
    for command in fish fish_indent fish_key_reader; do
        link="{{ .aqua.binDir }}/$command"
        if [ -L "$link" ]; then
            target=$(readlink "$link" || true)
            case "$target" in
                *aqua-proxy*) rm -f "$link" ;;
            esac
        fi
    done
}

remove_stale_aqua_fish_links
# {{ end }}

# {{ else }}
echo "aqua was not found at {{ .aqua.bin }}. Run chezmoi apply again after the bootstrap script installs it." >&2
exit 1
# {{ end }}
