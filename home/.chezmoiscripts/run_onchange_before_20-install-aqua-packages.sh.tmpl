#!/usr/bin/env bash

# {{- $aquaConfigSource := joinPath .chezmoi.sourceDir "dot_config/aquaproj-aqua/aqua.yaml" -}}
# {{- $aquaFishConfigSource := joinPath .chezmoi.sourceDir "dot_config/aquaproj-aqua/fish.yaml" -}}
#
# aqua.yaml.sha256={{ include $aquaConfigSource | sha256sum }}
# fish.yaml.sha256={{ include $aquaFishConfigSource | sha256sum }}

# {{- $fishPortable := dig "shell" "fish" "portable" false . }}
# shell.fish.portable={{ $fishPortable }}

set -euo pipefail

aqua_root="${AQUA_ROOT_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/aquaproj-aqua}"
aqua_global_config="{{ $aquaConfigSource }}"
aqua_enabled_config="$aqua_global_config"

if [ -x "$aqua_root/bin/aqua" ]; then
    aqua_bin="$aqua_root/bin/aqua"
elif command -v aqua >/dev/null 2>&1; then
    aqua_bin=$(command -v aqua)
else
    echo "aqua was not found. Run chezmoi apply again after the bootstrap script installs it." >&2
    exit 1
fi

if [ ! -r "$aqua_global_config" ]; then
    echo "Aqua global config was not found at $aqua_global_config." >&2
    exit 1
fi

# {{ if $fishPortable }}
aqua_fish_config="{{ $aquaFishConfigSource }}"

if [ ! -r "$aqua_fish_config" ]; then
    echo "Aqua fish config was not found at $aqua_fish_config." >&2
    exit 1
fi

aqua_enabled_config="$aqua_enabled_config:$aqua_fish_config"
# {{ end }}

remove_stale_aqua_fish_links() {
    local command link target

    # aqua install is additive: if fish was previously enabled and is later
    # removed from AQUA_GLOBAL_CONFIG, aqua does not prune the old proxy links
    # from bin/. Remove only aqua-proxy symlinks so shell.fish.portable=false
    # does not keep resolving fish from aqua ahead of system/Homebrew fish.
    for command in fish fish_indent fish_key_reader; do
        link="$aqua_root/bin/$command"
        if [ -L "$link" ]; then
            target=$(readlink "$link" || true)
            case "$target" in
                *aqua-proxy*) rm -f "$link" ;;
            esac
        fi
    done
}

export AQUA_ROOT_DIR="$aqua_root"
export AQUA_GLOBAL_CONFIG="$aqua_enabled_config"
"$aqua_bin" install --all

# {{ if not $fishPortable }}
remove_stale_aqua_fish_links
# {{ end }}
