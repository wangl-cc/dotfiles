#!/usr/bin/env bash
# Launch Claude Code against the Z.AI Anthropic-compatible endpoint with GLM.
# Token is read from a dedicated (unlocked) macOS keychain: ai-tokens.keychain.
set -euo pipefail

KEYCHAIN="$HOME/Library/Keychains/ai-tokens.keychain-db"

if [[ ! -f "$KEYCHAIN" ]]; then
  echo "claude-zai: keychain not found at $KEYCHAIN" >&2
  echo "See setup instructions at the top of $0" >&2
  exit 1
fi

TOKEN="$(security find-generic-password -s "claude-zai-token" -w "$KEYCHAIN" 2>/dev/null || true)"
if [[ -z "$TOKEN" ]]; then
  echo "claude-zai: no 'claude-zai-token' item in $KEYCHAIN" >&2
  echo "Add it with: security add-generic-password -a \"\$USER\" -s \"claude-zai-token\" -w \"$KEYCHAIN\"" >&2
  exit 1
fi

export ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
export ANTHROPIC_AUTH_TOKEN="$TOKEN"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="glm-4.5-air"
export ANTHROPIC_DEFAULT_SONNET_MODEL="glm-5.1"
export ANTHROPIC_DEFAULT_OPUS_MODEL="glm-5.1"
export API_TIMEOUT_MS="3000000"

# Avoid leaking any pre-existing Anthropic key from the parent shell.
unset ANTHROPIC_API_KEY

exec claude "$@"
