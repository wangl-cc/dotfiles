# .bashrc

# Source global definitions
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

if [ -d "$HOME/.config/shell/conf.d" ]; then
    for shell_config in "$HOME/.config/shell/conf.d/"*.sh; do
        [ -r "$shell_config" ] || continue
        . "$shell_config"
    done
    unset shell_config
fi
