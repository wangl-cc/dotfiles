{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.codex/hooks/rtk_pre_tool_use.py\"",
            "timeout": 5,
            "statusMessage": "Rewriting command through RTK"
          }
        ]
      }
    ]
  }
}
