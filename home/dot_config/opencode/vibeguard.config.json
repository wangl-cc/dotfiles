{
  "enabled": true,
  "patterns": [
    {
      "name": "OpenAI like API Key",
      "pattern": "sk-(?:[a-zA-Z]+-)?[a-zA-Z0-9]+",
      "category": "API_KEY"
    },
    {
      "name": "Generic Secret",
      "pattern": "(?:password|secret|token|key|access\"?)\\s*[=:]\\s*['\"\\S]+",
      "category": "SECRET"
    }
  ],
  "debug": false
}
