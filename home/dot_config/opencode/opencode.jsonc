{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "small_model": "openai/gpt-5.4-mini",
  "plugin": ["opencode-vibeguard", "opencode-pty"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    },
  },
  "agent": {
    "general": {
      "disable": true,
    },
    "explore": {
      "disable": true,
    },
  },
  "permission": {
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
  },
}
