{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "small_model": "openai/gpt-5.4-mini",
  "plugin": ["opencode-vibeguard", "opencode-pty"],
  "agent": {
    "general": {
      "disable": true,
    },
    "explore": {
      "disable": true,
    },
  },
  "permission": {
    "external_directory": {
      "/tmp/opencode/**": "allow",
    },
  },
}
