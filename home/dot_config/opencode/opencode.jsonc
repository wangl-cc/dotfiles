{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "small_model": "openai/gpt-5.4-mini",
  "plugin": ["opencode-vibeguard", "opencode-pty"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    },
  },
  "agent": {
    "build": {
      "disable": true,
    },
    "plan": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
  },
  "permission": {
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "bash": {
      "*": "ask",
      "rm -rf*": "deny",
      "rm -fr*": "deny",
      "sudo *": "deny",
      "chmod -R*": "deny",
      "chown -R*": "deny",
      "git reset --hard*": "deny",
      "git clean -fd*": "deny",
      "git clean -df*": "deny",
      "git clean -xfd*": "deny",
      "git clean -xdf*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git push --force-with-lease*": "ask",
      "git push --force-if-includes*": "ask",
      "pwd": "allow",
      "git status*": "allow",
      "git branch*": "allow",
      "git remote -v*": "allow",
      "git config --get*": "allow",
      "git rev-parse*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git log*": "allow",
      "git grep*": "allow",
      "git ls-files*": "allow",
      "git blame*": "allow",
      "bunx markdownlint-cli2*": "allow",
      "uvx ruff*": "allow",
      "typos": "allow",
      "typos *": "allow",
      "typos *--write-changes*": "deny",
      "typos --write-changes*": "deny",
      "typos * -w*": "deny",
      "typos -w*": "deny",
      "opencode --version*": "allow",
      "opencode debug config*": "allow",
      "opencode debug agent*": "allow",
    },
  },
}
