# Aqua global config and PATH entry.

# Keep the machine-local manifest first so `aqua generate -g -i` writes there.
# {{ $aquaGlobalConfig := list .aqua.localConfig .aqua.sharedConfig }}
# {{ if dig "shell" "fish" "portable" false . }}
# {{ $aquaGlobalConfig = append $aquaGlobalConfig .aqua.fishConfig }}
# {{ end }}
export AQUA_GLOBAL_CONFIG={{ $aquaGlobalConfig | join ":" | quote }}

export AQUA_ROOT_DIR="{{ .aqua.rootDir }}"

case ":$PATH:" in
    *":{{ .aqua.binDir }}:"*) ;;
    *) [ -d "{{ .aqua.binDir }}" ] && PATH="{{ .aqua.binDir }}:$PATH" ;;
esac

export PATH
