# Enter fish from interactive fallback bash/zsh shells without requiring chsh.

# {{ if dig "shell" "fish" "auto" true . }}
case "$-" in
    *i*) ;;
    *) return 0 ;;
esac

if [ "${_CHEZMOI_FISH_SESSION:-}" = "1" ] || [ -n "${FISH_VERSION:-}" ]; then
    return 0
fi

case "${SHELL:-}" in
    fish|*/fish) return 0 ;;
esac

# {{ $fishPortable := dig "shell" "fish" "portable" false . }}
# {{ if $fishPortable }}
# {{ $aquaFishConfig := joinPath .chezmoi.sourceDir "dot_config/aquaproj-aqua/fish.yaml" }}
# {{ $aquaBin := joinPath .chezmoi.homeDir ".local/share/aquaproj-aqua/bin/aqua" }}
fish_bin={{ output $aquaBin "--config" $aquaFishConfig "which" "fish" | trim | quote }}
# {{ else }}
fish_bin=$(command -v fish 2>/dev/null || true)
# {{ end }}

if [ -z "$fish_bin" ] || [ ! -x "$fish_bin" ]; then
    unset fish_bin
    return 0
fi

export SHELL="$fish_bin"
exec "$fish_bin" -l
# {{ end }}
